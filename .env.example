# Optional proxy routing. Off by default and fully inert when unset.
#
# When set, every IP-bearing fetch tier (Tier 1 httpx bulk, Tier 2 Playwright,
# Tier 3 Camoufox) is routed through the proxy so a high-volume scrape does not
# accrue a footprint against your own IP. Tier 1.5 (Jina Reader) always exits via
# r.jina.ai and is unaffected.
#
# Fail-closed: if a proxy is configured but cannot be wired, the run RAISES rather
# than silently leaking to your real IP. `run.py --doctor` probes the gateway and
# prints the exit IP so you can confirm routing before a bulk run.
#
# Value format: http://user:pass@host:port  (socks5://... also works for Tier 1)

# All IP-bearing tiers / bulk (alias: SCRAPE_PROXY_URL)
# SCRAPE_CASCADE_PROXY_URL=http://user:pass@gateway.example.com:8080

# Optional Tier-3 (stealth) override; falls back to the bulk proxy if unset
# (alias: SCRAPE_PROXY_URL_STEALTH)
# SCRAPE_CASCADE_PROXY_URL_STEALTH=http://user:pass@residential.example.com:8080

# Optional: override the local LLM CLI used by the judge.
# CODEX_BIN=codex
# CLAUDE_BIN=claude
# JUDGE_MODEL=haiku
